ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# Bot Shelly
BOT_PORT=3002
PIX_KEY=sua-chave-pix

# Airtable
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=schillings
WEBHOOK_DEBUG=false
# Fallback para testes quando @lid não resolve — ex: 5521967533689@s.whatsapp.net
FALLBACK_JID=

# Buffer (agendamento e publicação social)
BUFFER_ACCESS_TOKEN=
BUFFER_LINKEDIN_PROFILE_ID=
BUFFER_INSTAGRAM_PROFILE_ID=

# LinkedIn API (opcional, para integração direta)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Idioma do bot: "pt" (português, padrão) ou "en" (inglês)
BOT_LANGUAGE=pt

# Modo teste — restringe o bot a números específicos e desativa crons
# TEST_MODE=true   → ignora mensagens de qualquer número fora de TEST_NUMBERS
# TEST_NUMBERS     → lista separada por vírgula (ex: 5521999999999,5521888888888)
# CRON_ENABLED     → define se os jobs automáticos (lembretes, cobranças) ficam ativos
TEST_MODE=
TEST_NUMBERS=
CRON_ENABLED=
